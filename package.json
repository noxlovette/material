{
  "name": "@noxlovette/material",
  "version": "0.1.36",
  "type": "module",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/noxlovette/material.git"
  },
  "scripts": {
    "build": "svelte-package && bun scripts/copy-skill.ts",
    "prepublishOnly": "bun run build",
    "check": "svelte-kit sync && svelte-check",
    "test": "vitest run",
    "format": "prettier --write .",
    "dev": "vite dev"
  },
  "bin": {
    "material-claude-skill": "./bin/install-skill.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "claude-skill",
    "bin"
  ],
  "sideEffects": false,
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles": "./dist/index.css",
    "./theme/*": "./dist/styles/theme/*.css"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.58.0",
    "@tailwindcss/typography": "^0.5.19",
    "svelte": "^5.45.6",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "@internationalized/date": "^3.12.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.5",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.21",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.2",
    "sveltekit-superforms": "^2.30.2",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.8.0",
    "@internationalized/date": "^3.12.2",
    "@ktibow/material-color-utilities-nightly": "^0.4.1772748028000",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "nanoid": "^5.1.16",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  }
}
